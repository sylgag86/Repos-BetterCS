2025-05-13 11:00:24,793 - semgrep.rule_match - DEBUG - match_key = ('\n    document.addEventListener(\'DOMContentLoaded\', function() {\n      // Tab Elements\n      const tabFed = document.getElementById(\'tabFed\');\n      const tabMortgage = document.getElementById(\'tabMortgage\');\n      const tabPersonal = document.getElementById(\'tabPersonal\');\n      const tabBusiness = document.getElementById(\'tabBusiness\');\n      \n      // Chart Containers\n      const fedRateChart = document.getElementById(\'fedRateChart\');\n      const mortgageRateChart = document.getElementById(\'mortgageRateChart\');\n      const personalRateChart = document.getElementById(\'personalRateChart\');\n      const businessRateChart = document.getElementById(\'businessRateChart\');\n      \n      // Chart Context Element\n      const chartContext = document.getElementById(\'chartContext\');\n      \n      // Chart Data\n      const fedRateData = {\n        labels: [\'2016\', \'2017\', \'2018\', \'2019\', \'2020\', \'2021\', \'2022\', \'2023\', \'2024\', \'2025\'],\n        datasets: [{\n          label: \'Federal Funds Rate (%)\',\n          data: [0.63, 1.30, 2.40, 1.75, 0.25, 0.25, 4.33, 5.33, 4.83, 4.58],\n          borderColor: \'#3B82F6\',\n          backgroundColor: \'rgba(59, 130, 246, 0.1)\',\n          fill: true,\n          tension: 0.3,\n          pointRadius: 5,\n          pointBackgroundColor: \'#3B82F6\'\n        }]\n      };\n      \n      const mortgageRateData = {\n        labels: [\'2016\', \'2017\', \'2018\', \'2019\', \'2020\', \'2021\', \'2022\', \'2023\', \'2024\', \'2025\'],\n        datasets: [\n          {\n            label: \'30-Year Fixed (%)\',\n            data: [3.65, 3.99, 4.54, 3.94, 3.11, 2.96, 5.34, 6.61, 6.92, 6.95],\n            borderColor: \'#3B82F6\',\n            backgroundColor: \'rgba(59, 130, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#3B82F6\'\n          },\n          {\n            label: \'15-Year Fixed (%)\',\n            data: [2.91, 3.27, 3.98, 3.39, 2.61, 2.27, 4.60, 5.91, 6.25, 6.20],\n            borderColor: \'#8B5CF6\',\n            backgroundColor: \'rgba(139, 92, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#8B5CF6\'\n          }\n        ]\n      };\n      \n      const personalRateData = {\n        labels: [\'2016\', \'2017\', \'2018\', \'2019\', \'2020\', \'2021\', \'2022\', \'2023\', \'2024\', \'2025\'],\n        datasets: [\n          {\n            label: \'Excellent Credit (740+)\',\n            data: [10.94, 10.31, 10.12, 9.92, 9.50, 8.95, 10.73, 11.48, 8.99, 7.99],\n            borderColor: \'#3B82F6\',\n            backgroundColor: \'rgba(59, 130, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#3B82F6\'\n          },\n          {\n            label: \'Good Credit (670-739)\',\n            data: [13.56, 13.24, 13.50, 13.13, 12.45, 11.87, 13.54, 14.60, 11.53, 10.59],\n            borderColor: \'#8B5CF6\',\n            backgroundColor: \'rgba(139, 92, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#8B5CF6\'\n          },\n          {\n            label: \'Fair Credit (580-669)\',\n            data: [21.28, 20.89, 21.36, 20.68, 19.97, 19.33, 21.47, 23.55, 19.21, 17.80],\n            borderColor: \'#EC4899\',\n            backgroundColor: \'rgba(236, 72, 153, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#EC4899\'\n          }\n        ]\n      };\n      \n      const businessRateData = {\n        labels: [\'2016\', \'2017\', \'2018\', \'2019\', \'2020\', \'2021\', \'2022\', \'2023\', \'2024\', \'2025\'],\n        datasets: [\n          {\n            label: \'SBA 7(a) Loans\',\n            data: [6.25, 6.75, 7.75, 7.00, 5.75, 5.50, 9.00, 10.25, 9.50, 9.50],\n            borderColor: \'#3B82F6\',\n            backgroundColor: \'rgba(59, 130, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#3B82F6\'\n          },\n          {\n            label: \'Term Loans (Average)\',\n            data: [5.94, 6.54, 7.79, 6.98, 6.11, 5.96, 9.50, 12.48, 10.48, 9.52],\n            borderColor: \'#8B5CF6\',\n            backgroundColor: \'rgba(139, 92, 246, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#8B5CF6\'\n          },\n          {\n            label: \'Business Line of Credit\',\n            data: [6.80, 7.10, 8.30, 7.50, 6.80, 6.50, 9.75, 13.10, 11.30, 10.25],\n            borderColor: \'#EC4899\',\n            backgroundColor: \'rgba(236, 72, 153, 0.1)\',\n            tension: 0.3,\n            pointRadius: 4,\n            pointBackgroundColor: \'#EC4899\'\n          }\n        ]\n      };\n      \n      // Chart Context Text\n      const contextTexts = {\n        fed: `<p>The Federal Funds Rate is the interest rate at which banks lend reserve balances to other banks overnight. It\'s set by the Federal Reserve\'s Federal Open Market Committee (FOMC) and serves as a benchmark for many other interest rates throughout the economy.</p>\n              \n              <p>When the Federal Reserve increases the Federal Funds Rate, it generally leads to higher interest rates across various lending products, including mortgages, personal loans, business loans, and credit cards. Conversely, when the Fed lowers rates, borrowing costs tend to decrease.</p>\n              \n              <p>The chart above shows how the Federal Funds Rate has changed over the past several years. Notable periods include:</p>\n              \n              <ul>\n                <li>The near-zero rates following the 2008 financial crisis</li>\n                <li>The gradual increase from 2015 to 2019 as the economy strengthened</li>\n                <li>The rapid decrease in early 2020 in response to the COVID-19 pandemic</li>\n                <li>The subsequent increases starting in 2022 to combat inflation</li>\n              </ul>\n              \n              <p>Understanding these trends can help you time your borrowing decisions and anticipate potential changes in your variable-rate loans.</p>`,\n        \n        mortgage: `<p>Mortgage rates are influenced by a variety of factors, including the Federal Funds Rate, inflation expectations, the 10-year Treasury yield, and housing market conditions. While they don\'t move in perfect sync with the Federal Funds Rate, there is often a correlation between the two.</p>\n              \n              <p>The chart shows historical trends for both 30-year and 15-year fixed-rate mortgages. As you can see, 15-year mortgages typically offer lower interest rates than 30-year mortgages, but they come with higher monthly payments due to the shorter repayment period.</p>\n              \n              <p>Notable observations from the chart:</p>\n              \n              <ul>\n                <li>Mortgage rates hit historic lows in 2020-2021 during the COVID-19 pandemic</li>\n                <li>Rates increased dramatically in 2022-2023 as the Federal Reserve raised rates to combat inflation</li>\n                <li>While rates have stabilized, they remain significantly higher than the 2020-2021 lows</li>\n              </ul>\n              \n              <p>For homebuyers and those considering refinancing, understanding these trends is crucial for timing your mortgage decisions.</p>`,\n        \n        personal: `<p>Personal loan interest rates vary significantly based on the borrower\'s creditworthiness. As shown in the chart, individuals with excellent credit typically receive interest rates that are substantially lower than those with fair credit.</p>\n              \n              <p>Personal loan rates are influenced by the Federal Funds Rate, but lender-specific factors, competition, and risk assessment practices also play significant roles in determining the rates offered to consumers.</p>\n              \n              <p>Notable trends in personal loan rates:</p>\n              \n              <ul>\n                <li>Rates generally decreased from 2016 to 2021 as competition among lenders increased</li>\n                <li>The spread between excellent and fair credit rates has remained consistently wide, highlighting the importance of good credit</li>\n                <li>Rates increased significantly in 2022-2023 as the Federal Reserve raised interest rates</li>\n                <li>Recent decreases reflect both market competition and improved economic conditions</li>\n              </ul>\n              \n              <p>If you\'re considering a personal loan, improving your credit score before applying can result in substantial interest savings over the life of the loan.</p>`,\n        \n        business: `<p>Business loan interest rates vary based on the type of financing, loan term, and the creditworthiness of the business. SBA loans typically offer some of the most competitive rates for small businesses, while lines of credit often have higher rates due to their flexibility.</p>\n              \n              <p>The chart displays trends for three common types of business financing: SBA 7(a) loans, conventional term loans, and business lines of credit.</p>\n              \n              <p>Key observations from the business loan rate trends:</p>\n              \n              <ul>\n                <li>SBA loan rates are generally lower than other business financing options, reflecting their government backing</li>\n                <li>All business lending rates increased dramatically in 2022-2023 following Federal Reserve rate hikes</li>\n                <li>The spread between different financing types widens during periods of economic uncertainty</li>\n                <li>Recent moderation in rates reflects stabilizing monetary policy and economic conditions</li>\n              </ul>\n              \n              <p>For business owners, understanding these trends can help determine the optimal timing and type of financing for your specific needs. Additionally, maintaining strong business credit can significantly impact the rates you\'re offered.</p>`\n      };\n      \n      // Initialize Charts\n      const fedChart = new Chart(\n        document.getElementById(\'fedRateCanvas\'),\n        {\n          type: \'line\',\n          data: fedRateData,\n          options: {\n            responsive: true,\n            maintainAspectRatio: false,\n            plugins: {\n              title: {\n                display: true,\n                text: \'Federal Funds Rate (2016-2025)\',\n                font: {\n                  size: 16,\n                  weight: \'bold\'\n                }\n              },\n              tooltip: {\n                mode: \'index\',\n                intersect: false\n              }\n            },\n            scales: {\n              y: {\n                beginAtZero: true,\n                title: {\n                  display: true,\n                  text: \'Interest Rate (%)\'\n                },\n                ticks: {\n                  callback: function(value) {\n                    return value + \'%\';\n                  }\n                }\n              },\n              x: {\n                title: {\n                  display: true,\n                  text: \'Year\'\n                }\n              }\n            }\n          }\n        }\n      );\n      \n      const mortgageChart = new Chart(\n        document.getElementById(\'mortgageRateCanvas\'),\n        {\n          type: \'line\',\n          data: mortgageRateData,\n          options: {\n            responsive: true,\n            maintainAspectRatio: false,\n            plugins: {\n              title: {\n                display: true,\n                text: \'Mortgage Interest Rates (2016-2025)\',\n                font: {\n                  size: 16,\n                  weight: \'bold\'\n                }\n              },\n              tooltip: {\n                mode: \'index\',\n                intersect: false\n              }\n            },\n            scales: {\n              y: {\n                beginAtZero: true,\n                title: {\n                  display: true,\n                  text: \'Interest Rate (%)\'\n                },\n                ticks: {\n                  callback: function(value) {\n                    return value + \'%\';\n                  }\n                }\n              },\n              x: {\n                title: {\n                  display: true,\n                  text: \'Year\'\n                }\n              }\n            }\n          }\n        }\n      );\n      \n      const personalChart = new Chart(\n        document.getElementById(\'personalRateCanvas\'),\n        {\n          type: \'line\',\n          data: personalRateData,\n          options: {\n            responsive: true,\n            maintainAspectRatio: false,\n            plugins: {\n              title: {\n                display: true,\n                text: \'Personal Loan Interest Rates by Credit Score (2016-2025)\',\n                font: {\n                  size: 16,\n                  weight: \'bold\'\n                }\n              },\n              tooltip: {\n                mode: \'index\',\n                intersect: false\n              }\n            },\n            scales: {\n              y: {\n                beginAtZero: true,\n                title: {\n                  display: true,\n                  text: \'Interest Rate (%)\'\n                },\n                ticks: {\n                  callback: function(value) {\n                    return value + \'%\';\n                  }\n                }\n              },\n              x: {\n                title: {\n                  display: true,\n         