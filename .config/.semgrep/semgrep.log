}\n        }\n      );\n      \n      // Tab Switching Logic\n      function setupTabs() {\n        tabFed.addEventListener(\'click\', () => {\n          // Update active tab\n          tabFed.classList.add(\'border-primary\', \'text-primary\');\n          tabMortgage.classList.remove(\'border-primary\', \'text-primary\');\n          tabPersonal.classList.remove(\'border-primary\', \'text-primary\');\n          tabBusiness.classList.remove(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          fedRateChart.classList.remove(\'hidden\');\n          mortgageRateChart.classList.add(\'hidden\');\n          personalRateChart.classList.add(\'hidden\');\n          businessRateChart.classList.add(\'hidden\');\n          \n          // Update context\n          chartContext.innerHTML = contextTexts.fed;\n        });\n        \n        tabMortgage.addEventListener(\'click\', () => {\n          // Update active tab\n          tabFed.classList.remove(\'border-primary\', \'text-primary\');\n          tabMortgage.classList.add(\'border-primary\', \'text-primary\');\n          tabPersonal.classList.remove(\'border-primary\', \'text-primary\');\n          tabBusiness.classList.remove(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          fedRateChart.classList.add(\'hidden\');\n          mortgageRateChart.classList.remove(\'hidden\');\n          personalRateChart.classList.add(\'hidden\');\n          businessRateChart.classList.add(\'hidden\');\n          \n          // Update context\n          chartContext.innerHTML = contextTexts.mortgage;\n        });\n        \n        tabPersonal.addEventListener(\'click\', () => {\n          // Update active tab\n          tabFed.classList.remove(\'border-primary\', \'text-primary\');\n          tabMortgage.classList.remove(\'border-primary\', \'text-primary\');\n          tabPersonal.classList.add(\'border-primary\', \'text-primary\');\n          tabBusiness.classList.remove(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          fedRateChart.classList.add(\'hidden\');\n          mortgageRateChart.classList.add(\'hidden\');\n          personalRateChart.classList.remove(\'hidden\');\n          businessRateChart.classList.add(\'hidden\');\n          \n          // Update context\n          chartContext.innerHTML = contextTexts.personal;\n        });\n        \n        tabBusiness.addEventListener(\'click\', () => {\n          // Update active tab\n          tabFed.classList.remove(\'border-primary\', \'text-primary\');\n          tabMortgage.classList.remove(\'border-primary\', \'text-primary\');\n          tabPersonal.classList.remove(\'border-primary\', \'text-primary\');\n          tabBusiness.classList.add(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          fedRateChart.classList.add(\'hidden\');\n          mortgageRateChart.classList.add(\'hidden\');\n          personalRateChart.classList.add(\'hidden\');\n          businessRateChart.classList.remove(\'hidden\');\n          \n          // Update context\n          chartContext.innerHTML = contextTexts.business;\n        });\n      }\n      \n      // Initialize tabs\n      setupTabs();\n    });\n  </script>\n', PosixPath('client/public/resources/interest-rate-trends.html'), 'config..semgrep.vendored-rules.html.security.audit.insecure-document-method') match_id = 7f6c68f5fdebef201b8014d27d879b501e820463a4e60e98817f521e19b4e5363afc68a5fd867179f2382cd3bd72bef5bb923255b56645cc9f1f6fd7ee6e39c5_0
