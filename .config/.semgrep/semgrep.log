} A50,50 0 ${feesPct > 50 ? 1 : 0},1 50,0 Z" fill="${colors.fees}" class="pie-segment"></path>` : \'\'}\n            </svg>\n            <div class="mt-4 text-sm space-y-1">\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-primary mr-2"></span>\n                <span>Principal: ${formatCurrency(loan.principal)} (${principalPct.toFixed(1)}%)</span>\n              </div>\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-amber-500 mr-2"></span>\n                <span>Interest: ${formatCurrency(loan.totalInterest)} (${interestPct.toFixed(1)}%)</span>\n              </div>\n              ${feesPct > 0 ? `\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-pink-500 mr-2"></span>\n                <span>Fees: ${formatCurrency(loan.originationFees)} (${feesPct.toFixed(1)}%)</span>\n              </div>\n              ` : \'\'}\n            </div>\n          `;\n        });\n      }\n      \n      // Determine best loan and generate recommendation\n      function generateRecommendation(loans) {\n        const validLoans = loans.filter(Boolean);\n        if (validLoans.length < 2) return;\n        \n        // Find best loan based on total cost\n        let bestLoanIndex = 0;\n        let lowestCost = validLoans[0].totalCost;\n        \n        validLoans.forEach((loan, index) => {\n          if (loan.totalCost < lowestCost) {\n            lowestCost = loan.totalCost;\n            bestLoanIndex = index;\n          }\n        });\n        \n        // Get loan names\n        const loanNames = validLoans.map((loan, index) => {\n          const inputElement = document.getElementById(`loan${loans.indexOf(loan) + 1}Name`);\n          return inputElement.value || `Option ${loans.indexOf(loan) + 1}`;\n        });\n        \n        // Highlight the best card\n        comparisonCards.querySelectorAll(\'.comparison-card\').forEach(card => {\n          card.classList.remove(\'highlighted\');\n        });\n        \n        const bestCard = document.getElementById(`card${loans.indexOf(validLoans[bestLoanIndex]) + 1}`);\n        if (bestCard) bestCard.classList.add(\'highlighted\');\n        \n        // Generate recommendation text\n        const bestLoanName = loanNames[bestLoanIndex];\n        const savings = validLoans.map(loan => loan.totalCost - validLoans[bestLoanIndex].totalCost);\n        \n        // Create recommendation text\n        let recommendation = `<p class="text-lg mb-3">Based on total cost, <span class="font-semibold text-primary">${bestLoanName}</span> appears to be the best option.</p>`;\n        recommendation += `<p class="mb-3">With ${bestLoanName}, you would pay a total of ${formatCurrency(validLoans[bestLoanIndex].totalCost)} over the life of the loan.</p>`;\n        \n        // Add savings comparisons\n        if (validLoans.length > 1) {\n          recommendation += `<div class="mt-4"><p class="font-medium mb-2">Potential savings with ${bestLoanName}:</p><ul class="space-y-1 ml-5 list-disc">`;\n          \n          validLoans.forEach((loan, index) => {\n            if (index === bestLoanIndex) return;\n            \n            recommendation += `<li>Save ${formatCurrency(savings[index])} compared to ${loanNames[index]}</li>`;\n          });\n          \n          recommendation += `</ul></div>`;\n        }\n        \n        // Update recommendation\n        recommendationSection.classList.remove(\'hidden\');\n        recommendationText.innerHTML = recommendation;\n      }\n      \n      // Handle tab switching\n      function setupTabs() {\n        tabMonthly.addEventListener(\'click\', () => {\n          // Update active tab\n          tabMonthly.classList.add(\'border-primary\', \'text-primary\');\n          tabTotal.classList.remove(\'border-primary\', \'text-primary\');\n          tabInterest.classList.remove(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          monthlyChart.classList.remove(\'hidden\');\n          totalChart.classList.add(\'hidden\');\n          interestChart.classList.add(\'hidden\');\n        });\n        \n        tabTotal.addEventListener(\'click\', () => {\n          // Update active tab\n          tabMonthly.classList.remove(\'border-primary\', \'text-primary\');\n          tabTotal.classList.add(\'border-primary\', \'text-primary\');\n          tabInterest.classList.remove(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          monthlyChart.classList.add(\'hidden\');\n          totalChart.classList.remove(\'hidden\');\n          interestChart.classList.add(\'hidden\');\n        });\n        \n        tabInterest.addEventListener(\'click\', () => {\n          // Update active tab\n          tabMonthly.classList.remove(\'border-primary\', \'text-primary\');\n          tabTotal.classList.remove(\'border-primary\', \'text-primary\');\n          tabInterest.classList.add(\'border-primary\', \'text-primary\');\n          \n          // Show/hide content\n          monthlyChart.classList.add(\'hidden\');\n          totalChart.classList.add(\'hidden\');\n          interestChart.classList.remove(\'hidden\');\n        });\n      }\n      \n      // Handle compare button click\n      compareBtn.addEventListener(\'click\', function() {\n        // Calculate loan details\n        const loan1 = calculateLoanDetails(loan1Amount.value, loan1Rate.value, loan1Term.value, loan1Fees.value);\n        const loan2 = calculateLoanDetails(loan2Amount.value, loan2Rate.value, loan2Term.value, loan2Fees.value);\n        const loan3 = calculateLoanDetails(loan3Amount.value, loan3Rate.value, loan3Term.value, loan3Fees.value);\n        \n        const loans = [loan1, loan2, loan3];\n        \n        // Generate comparison cards\n        comparisonCards.innerHTML = \'\';\n        loans.forEach((loan, index) => {\n          if (loan) {\n            comparisonCards.innerHTML += createComparisonCard(index + 1, loan);\n          }\n        });\n        \n        // Update header names\n        header1.textContent = loan1Name.value || \'Option 1\';\n        header2.textContent = loan2Name.value || \'Option 2\';\n        header3.textContent = loan3Name.value || \'Option 3\';\n        \n        // Show results header if there\'s at least one valid loan\n        if (loans.some(Boolean)) {\n          resultsHeader.classList.remove(\'hidden\');\n        } else {\n          resultsHeader.classList.add(\'hidden\');\n        }\n        \n        // Generate charts\n        generateBarCharts(loans);\n        generatePieCharts(loans);\n        \n        // Generate recommendation\n        generateRecommendation(loans);\n      });\n      \n      // Initialize tabs\n      setupTabs();\n      \n      // Initial comparison\n      compareBtn.click();\n    });\n   $X $X. ... .$V = "..." $X. ... .innerHTML = ... $X. ... .outerHTML = ... javascript <script ...>\n    document.addEventListener(\'DOMContentLoaded\', function() {\n      // Elements\n      const compareBtn = document.getElementById(\'compareBtn\');\n      const comparisonCards = document.getElementById(\'comparisonCards\');\n      const recommendationSection = document.getElementById(\'recommendationSection\');\n      const recommendationText = document.getElementById(\'recommendationText\');\n      const resultsHeader = document.getElementById(\'resultsHeader\');\n      \n      // Input Elements\n      const loan1Name = document.getElementById(\'loan1Name\');\n      const loan1Amount = document.getElementById(\'loan1Amount\');\n      const loan1Rate = document.getElementById(\'loan1Rate\');\n      const loan1Term = document.getElementById(\'loan1Term\');\n      const loan1Fees = document.getElementById(\'loan1Fees\');\n      \n      const loan2Name = document.getElementById(\'loan2Name\');\n      const loan2Amount = document.getElementById(\'loan2Amount\');\n      const loan2Rate = document.getElementById(\'loan2Rate\');\n      const loan2Term = document.getElementById(\'loan2Term\');\n      const loan2Fees = document.getElementById(\'loan2Fees\');\n      \n      const loan3Name = document.getElementById(\'loan3Name\');\n      const loan3Amount = document.getElementById(\'loan3Amount\');\n      const loan3Rate = document.getElementById(\'loan3Rate\');\n      const loan3Term = document.getElementById(\'loan3Term\');\n      const loan3Fees = document.getElementById(\'loan3Fees\');\n      \n      // Chart Elements\n      const monthlyPaymentChart = document.getElementById(\'monthlyPaymentChart\');\n      const totalCostChart = document.getElementById(\'totalCostChart\');\n      const monthlyChartLabels = document.getElementById(\'monthlyChartLabels\');\n      const totalCostChartLabels = document.getElementById(\'totalCostChartLabels\');\n      \n      // Tab Elements\n      const tabMonthly = document.getElementById(\'tabMonthly\');\n      const tabTotal = document.getElementById(\'tabTotal\');\n      const tabInterest = document.getElementById(\'tabInterest\');\n      const monthlyChart = document.getElementById(\'monthlyChart\');\n      const totalChart = document.getElementById(\'totalChart\');\n      const interestChart = document.getElementById(\'interestChart\');\n      \n      // Header Elements\n      const header1 = document.getElementById(\'header1\');\n      const header2 = document.getElementById(\'header2\');\n      const header3 = document.getElementById(\'header3\');\n      \n      // Pie Chart Containers\n      const pie1Container = document.getElementById(\'pie1Container\');\n      const pie2Container = document.getElementById(\'pie2Container\');\n      const pie3Container = document.getElementById(\'pie3Container\');\n      \n      // Format currency\n      function formatCurrency(value) {\n        return new Intl.NumberFormat(\'en-US\', {\n          style: \'currency\',\n          currency: \'USD\',\n          minimumFractionDigits: 2,\n          maximumFractionDigits: 2\n        }).format(value);\n      }\n      \n      // Calculate monthly payment\n      function calculateMonthlyPayment(principal, interestRate, termYears) {\n        const monthlyRate = interestRate / 100 / 12;\n        const termMonths = termYears * 12;\n        return principal * monthlyRate * Math.pow(1 + monthlyRate, termMonths) / (Math.pow(1 + monthlyRate, termMonths) - 1);\n      }\n      \n      // Calculate total interest\n      function calculateTotalInterest(monthlyPayment, termYears, principal) {\n        return (monthlyPayment * termYears * 12) - principal;\n      }\n      \n      // Calculate loan details\n      function calculateLoanDetails(amount, rate, term, fees) {\n        if (!amount || !rate || !term) return null;\n        \n        const principal = parseFloat(amount);\n        const interestRate = parseFloat(rate);\n        const termYears = parseInt(term);\n        const originationFees = parseFloat(fees || 0);\n        \n        const monthlyPayment = calculateMonthlyPayment(principal, interestRate, termYears);\n        const totalInterest = calculateTotalInterest(monthlyPayment, termYears, principal);\n        const totalCost = principal + totalInterest + originationFees;\n        \n        return {\n          principal,\n          monthlyPayment,\n          totalInterest,\n          totalCost,\n          termYears,\n          interestRate,\n          originationFees\n        };\n      }\n      \n      // Create comparison card\n      function createComparisonCard(index, loan) {\n        if (!loan) return \'\';\n        \n        const name = document.getElementById(`loan${index}Name`).value || `Option ${index}`;\n        \n        return `\n          <div class="bg-white rounded-xl shadow-md p-6 border border-neutral-200 flex-1 comparison-card" id="card${index}">\n            <h3 class="text-xl font-semibold text-center mb-4">${name}</h3>\n            <div class="space-y-4">\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100">\n                <span class="text-neutral-600">Loan Amount</span>\n                <span class="font-medium">${formatCurrency(loan.principal)}</span>\n              </div>\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100">\n                <span class="text-neutral-600">Interest Rate</span>\n                <span class="font-medium">${loan.interestRate}%</span>\n              </div>\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100">\n                <span class="text-neutral-600">Term</span>\n                <span class="font-medium">${loan.termYears} years</span>\n              </div>\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100">\n                <span class="text-neutral-600">Origination Fee</span>\n                <span class="font-medium">${formatCurrency(loan.originationFees)}</span>\n              </div>\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100 bg-neutral-50 rounded px-2">\n                <span class="text-neutral-700 font-medium">Monthly Payment</span>\n                <span class="font-bold text-primary">${formatCurrency(loan.monthlyPayment)}</span>\n              </div>\n              <div class="flex justify-between items-center py-2 border-b border-neutral-100">\n                <span class="text-neutral-600">Total Interest</span>\n                <span class="font-medium">${formatCurrency(loan.totalInterest)}</span>\n              </div>\n              <div class="flex justify-between items-center py-2 bg-neutral-50 rounded px-2">\n                <span class="text-neutral-700 font-medium">Total Cost</span>\n                <span class="font-bold">${formatCurrency(loan.totalCost)}</span>\n              </div>\n            </div>\n          </div>\n        `;\n      }\n      \n      // Generate bar charts\n      function generateBarCharts(loans) {\n        // Clear previous charts\n        monthlyPaymentChart.innerHTML = \'\';\n        totalCostChart.innerHTML = \'\';\n        monthlyChartLabels.innerHTML = \'\';\n        totalCostChartLabels.innerHTML = \'\';\n        \n        // Find max values for scaling\n        const maxMonthly = Math.max(...loans.filter(Boolean).map(loan => loan.monthlyPayment));\n        const maxTotal = Math.max(...loans.filter(Boolean).map(loan => loan.totalCost));\n        \n        // Colors for the bars\n        const colors = [\'#3B82F6\', \'#8B5CF6\', \'#EC4899\'];\n        \n        // Generate monthly payment bars\n        loans.forEach((loan, index) => {\n          if (!loan) return;\n          \n          const name = document.getElementById(`loan${index + 1}Name`).value || `Option ${index + 1}`;\n          const heightPercentage = (loan.monthlyPayment / maxMonthly) * 100;\n          \n          // Create bar\n          const bar = document.createElement(\'div\');\n          bar.className = \'chart-bar\';\n          bar.style.height = `${heightPercentage}%`;\n          bar.style.backgroundColor = colors[index];\n          monthlyPaymentChart.appendChild(bar);\n          \n          // Create label\n          const label = document.createElement(\'div\');\n          label.className = \'text-center\';\n          label.innerHTML = `\n            <div style="color:${colors[index]}" class="font-medium">${name}</div>\n            <div class="text-sm text-neutral-600">${formatCurrency(loan.monthlyPayment)}</div>\n          `;\n          monthlyChartLabels.appendChild(label);\n        });\n        \n        // Generate total cost bars\n        loans.forEach((loan, index) => {\n          if (!loan) return;\n          \n          const name = document.getElementById(`loan${index + 1}Name`).value || `Option ${index + 1}`;\n          const heightPercentage = (loan.totalCost / maxTotal) * 100;\n          \n          // Create bar\n          const bar = document.createElement(\'div\');\n          bar.className = \'chart-bar\';\n          bar.style.height = `${heightPercentage}%`;\n          bar.style.backgroundColor = colors[index];\n          totalCostChart.appendChild(bar);\n          \n          // Create label\n          const label = document.createElement(\'div\');\n          label.className = \'text-center\';\n          label.innerHTML = `\n            <div style="color:${colors[index]}" class="font-medium">${name}</div>\n            <div class="text-sm text-neutral-600">${formatCurrency(loan.totalCost)}</div>\n          `;\n          totalCostChartLabels.appendChild(label);\n        });\n      }\n      \n      // Generate pie charts for principal vs interest\n      function generatePieCharts(loans) {\n        // Clear previous charts\n        pie1Container.innerHTML = \'\';\n        pie2Container.innerHTML = \'\';\n        pie3Container.innerHTML = \'\';\n        \n        // Colors\n        const colors = {\n          principal: \'#3B82F6\',\n          interest: \'#F59E0B\',\n          fees: \'#EC4899\'\n        };\n        \n        // Generate SVG pie charts\n        loans.forEach((loan, index) => {\n          if (!loan) return;\n          \n          const container = document.getElementById(`pie${index + 1}Container`);\n          const name = document.getElementById(`loan${index + 1}Name`).value || `Option ${index + 1}`;\n          \n          // Calculate percentages\n          const total = loan.principal + loan.totalInterest + loan.originationFees;\n          const principalPct = (loan.principal / total) * 100;\n          const interestPct = (loan.totalInterest / total) * 100;\n          const feesPct = (loan.originationFees / total) * 100;\n          \n          // Create SVG pie chart\n          container.innerHTML = `\n            <h4 class="text-lg font-medium mb-2">${name}</h4>\n            <svg width="200" height="200" viewBox="0 0 100 100">\n              <!-- Principal Segment (Starting at top, going clockwise) -->\n              <path d="M50,50 L50,0 A50,50 0 ${principalPct > 50 ? 1 : 0},1 ${50 + 50 * Math.sin(principalPct * 0.062832)},${50 - 50 * Math.cos(principalPct * 0.062832)} Z" fill="${colors.principal}" class="pie-segment"></path>\n              \n              <!-- Interest Segment -->\n              <path d="M50,50 L${50 + 50 * Math.sin(principalPct * 0.062832)},${50 - 50 * Math.cos(principalPct * 0.062832)} A50,50 0 ${interestPct > 50 ? 1 : 0},1 ${50 + 50 * Math.sin((principalPct + interestPct) * 0.062832)},${50 - 50 * Math.cos((principalPct + interestPct) * 0.062832)} Z" fill="${colors.interest}" class="pie-segment"></path>\n              \n              <!-- Fees Segment (if fees > 0) -->\n              ${feesPct > 0 ? `<path d="M50,50 L${50 + 50 * Math.sin((principalPct + interestPct) * 0.062832)},${50 - 50 * Math.cos((principalPct + interestPct) * 0.062832)} A50,50 0 ${feesPct > 50 ? 1 : 0},1 50,0 Z" fill="${colors.fees}" class="pie-segment"></path>` : \'\'}\n            </svg>\n            <div class="mt-4 text-sm space-y-1">\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-primary mr-2"></span>\n                <span>Principal: ${formatCurrency(loan.principal)} (${principalPct.toFixed(1)}%)</span>\n              </div>\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-amber-500 mr-2"></span>\n                <span>Interest: ${formatCurrency(loan.totalInterest)} (${interestPct.toFixed(1)}%)</span>\n              </div>\n              ${feesPct > 0 ? `\n              <div class="flex items-center">\n                <span class="inline-block w-3 h-3 bg-pink-500 mr-2"></span>\n                <span>Fees: ${formatCurrency(loan.originationFees)} (${feesPct.toFixed(1)}%)</span>\n              </div>\n              ` : \'\'}\n            </div>\n          `;\n        });\n      }\n      \n      // Determine best loan and generate recommendation\n      function generateRecommendation(loans) {\n        const validLoans = loans.filter(Boolean);\n        if (validLoans.length < 2) return;\n        \n        // Find best loan based on total cost\n        let bestLoanIndex = 0;\n        let lowestCost = validLoans[0].totalCost;\n        \n        validLoans.forEach((loan, index) => {\n          if (loan.totalCost < lowestCost) {\n            lowestCost = loan.totalCost;\n            bestLoanIndex = index;\n          }\n        });\n        \n        // Get loan names\n        const loanNames = validLoans.map((loan, index) => {\n          const inputElement = document.getElementById(`loan${loans.indexOf(loan) + 1}Name`);\n          return inputElement.value || `Option ${loans.indexOf(loan) + 1}`;\n        });\n        \n        // Highlight the best card\n        comparisonCards.querySelectorAll(\'.comparison-card\').forEach(card => {\n          card.classList.remove(\'highlighted\');\n        });\n        \n        const bestCard = document.getElementById(`card${loans.indexOf(validLoans[bestLoanIndex]) + 1}`);\n        if (bestCard) bestCard.classList.add(\'highlighted\');\n        \n        // Generate recommendation text\n        const bestLoanName = loanNames[bestLoanIndex];\n        const savings = validLoans.map(loan => loan.totalCost - validLoans[bestLoanIndex].totalCost);\n        \n        // Create recommendation text\n        let recommendation = `<p class="text-lg mb-3">Based on total cost, <span class="font-semibold text-primary">${bestLoanName}</span> appears to be the best option.</p>`;\n        recommendation += `<p class="mb-3">With ${bestLoanName}, you would pay a total of ${formatCurrency(validLoans[bestLoanIndex].totalCost)} over the life of the loan.</p>`;\n        \n        // Add savings comparisons\n        if (validLoans.length > 1) {\n          recommendation += `<div class="mt-4"><p class="font-medium mb-2">Potential savings with ${bestLoanName}