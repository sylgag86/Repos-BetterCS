2025-05-13 11:00:24,731 - semgrep.rule_match - DEBUG - match_key = ('\n    document.addEventListener(\'DOMContentLoaded\', function() {\n      // Elements\n      const blogSearch = document.getElementById(\'blogSearch\');\n      const categoryButtons = document.querySelectorAll(\'.category-badge\');\n      const blogCards = document.querySelectorAll(\'.blog-card\');\n      \n      // Filter articles by category\n      function filterByCategory(category) {\n        // Update active category button\n        categoryButtons.forEach(button => {\n          button.classList.remove(\'active\');\n          if (button.getAttribute(\'data-category\') === category) {\n            button.classList.add(\'active\');\n          }\n        });\n        \n        // Show/hide blog cards based on category\n        blogCards.forEach(card => {\n          if (category === \'all\' || card.getAttribute(\'data-category\') === category) {\n            card.classList.remove(\'hidden\');\n          } else {\n            card.classList.add(\'hidden\');\n          }\n        });\n      }\n      \n      // Search articles by keyword\n      function searchArticles(query) {\n        const searchTerms = query.toLowerCase().trim();\n        \n        if (!searchTerms) {\n          blogCards.forEach(card => {\n            card.classList.remove(\'hidden\');\n          });\n          return;\n        }\n        \n        blogCards.forEach(card => {\n          const title = card.querySelector(\'h3\').textContent.toLowerCase();\n          const description = card.querySelector(\'p\').textContent.toLowerCase();\n          const category = card.getAttribute(\'data-category\').toLowerCase();\n          \n          if (title.includes(searchTerms) || description.includes(searchTerms) || category.includes(searchTerms)) {\n            card.classList.remove(\'hidden\');\n          } else {\n            card.classList.add(\'hidden\');\n          }\n        });\n      }\n      \n      // Event Listeners\n      \n      // Category filtering\n      categoryButtons.forEach(button => {\n        button.addEventListener(\'click\', function() {\n          const category = this.getAttribute(\'data-category\');\n          filterByCategory(category);\n          \n          // Reset search when changing categories\n          blogSearch.value = \'\';\n        });\n      });\n      \n      // Search functionality\n      blogSearch.addEventListener(\'input\', function() {\n        const query = this.value;\n        searchArticles(query);\n        \n        // Reset category to "All" when searching\n        categoryButtons.forEach(button => {\n          button.classList.remove(\'active\');\n          if (button.getAttribute(\'data-category\') === \'all\') {\n            button.classList.add(\'active\');\n          }\n        });\n      });\n      \n      // Initialize with all articles visible\n      filterByCategory(\'all\');\n      \n      // Newsletter Modal Functionality\n      const readMoreLinks = document.querySelectorAll(\'a\');\n      const newsletterModal = document.getElementById(\'newsletter-modal\');\n      const closeModalBtn = document.getElementById(\'close-modal\');\n      const newsletterForm = document.getElementById(\'newsletter-popup-form\');\n      \n      // Handle all "Read More" links\n      const allReadMoreLinks = document.querySelectorAll(\'a.text-primary\');\n      \n      // All links now point directly to their respective article pages, \n      // so we don\'t need to handle any special cases\n      \n      // For reference only - we\'re not using this anymore\n      // const readMoreSpecificLinks = document.querySelectorAll(\'a.read-more-link\');\n      \n      /*\n      // We\'ve updated all links to direct article links, so this is no longer needed\n      readMoreSpecificLinks.forEach(link => {\n        link.addEventListener(\'click\', function(e) {\n          e.preventDefault();\n          \n          // Store default article link\n          localStorage.setItem(\'currentArticleLink\', \'/resources/articles/business-loan-options-for-startups.html\');\n          \n          // Show newsletter popup\n          newsletterModal.classList.remove(\'hidden\');\n        });\n      });\n      */\n      \n      // Close modal when clicking close button\n      if (closeModalBtn) {\n        closeModalBtn.addEventListener(\'click\', function() {\n          newsletterModal.classList.add(\'hidden\');\n        });\n      }\n      \n      // Close modal when clicking outside\n      if (newsletterModal) {\n        newsletterModal.addEventListener(\'click\', function(e) {\n          if (e.target === newsletterModal || e.target === newsletterModal.firstElementChild) {\n            newsletterModal.classList.add(\'hidden\');\n          }\n        });\n      }\n      \n      // Handle form submission\n      if (newsletterForm) {\n        // Handle Read Article button click\n        const readArticleBtn = document.getElementById(\'read-article-btn\');\n        if (readArticleBtn) {\n          readArticleBtn.addEventListener(\'click\', function() {\n            // Store in localStorage that user has accessed articles\n            localStorage.setItem(\'hasAccessedArticles\', \'true\');\n            \n            // Close the modal\n            newsletterModal.classList.add(\'hidden\');\n            \n            // Navigate to the article if we have one\n            const currentArticleLink = localStorage.getItem(\'currentArticleLink\');\n            if (currentArticleLink) {\n              window.location.href = currentArticleLink;\n            }\n          });\n        }\n        \n        newsletterForm.addEventListener(\'submit\', function(e) {\n          e.preventDefault();\n          \n          // Get form values\n          const email = document.getElementById(\'popup-email\').value;\n          const name = document.getElementById(\'popup-name\').value;\n          \n          // Store in localStorage that user has subscribed\n          localStorage.setItem(\'hasSubscribed\', \'true\');\n          localStorage.setItem(\'subscriberEmail\', email);\n          localStorage.setItem(\'hasAccessedArticles\', \'true\');\n          \n          // Show success message\n          const formContent = newsletterForm.innerHTML;\n          newsletterForm.innerHTML = `\n            <div class="text-center py-4">\n              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-success/20 text-success mb-4">\n                <i class="fas fa-check text-xl"></i>\n              </div>\n              <h4 class="text-lg font-medium text-neutral-900 mb-2">Thank You for Subscribing!</h4>\n              <p class="text-neutral-600">You now have full access to our premium content.</p>\n            </div>\n          `;\n          \n          // Close modal after 3 seconds\n          setTimeout(function() {\n            newsletterModal.classList.add(\'hidden\');\n            // Reset form for next time\n            setTimeout(function() {\n              newsletterForm.innerHTML = formContent;\n            }, 500);\n          }, 3000);\n        });\n      }\n    });\n   $X $X. ... .$V = "..." $X. ... .innerHTML = ... $X. ... .outerHTML = ... javascript <script ...>\n    document.addEventListener(\'DOMContentLoaded\', function() {\n      // Elements\n      const blogSearch = document.getElementById(\'blogSearch\');\n      const categoryButtons = document.querySelectorAll(\'.category-badge\');\n      const blogCards = document.querySelectorAll(\'.blog-card\');\n      \n      // Filter articles by category\n      function filterByCategory(category) {\n        // Update active category button\n        categoryButtons.forEach(button => {\n          button.classList.remove(\'active\');\n          if (button.getAttribute(\'data-category\') === category) {\n            button.classList.add(\'active\');\n          }\n        });\n        \n        // Show/hide blog cards based on category\n        blogCa